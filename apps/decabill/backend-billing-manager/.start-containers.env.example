# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=billing

# CORS configuration (comma-separated list of allowed origins)
# Example: CORS_ORIGIN=http://localhost:4200,http://localhost:4201
CORS_ORIGIN=

# Encryption key for sensitive data (base64 encoded)
ENCRYPTION_KEY=

# Authentication method: api-key | keycloak | users
# - api-key: Static API key auth (requires STATIC_API_KEY)
# - keycloak: Keycloak OAuth2 (requires Keycloak env vars)
# - users: Built-in user registration with JWT (requires JWT_SECRET)
AUTHENTICATION_METHOD=api-key

# Environment variables for static API key authentication (when AUTHENTICATION_METHOD=api-key)
STATIC_API_KEY=

# Environment variables for users authentication (when AUTHENTICATION_METHOD=users)
JWT_SECRET=

# Environment variables for Keycloak authentication (when AUTHENTICATION_METHOD=keycloak)
KEYCLOAK_SERVER_URL=
KEYCLOAK_AUTH_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_TOKEN_VALIDATION=online

# Custom billing / e-invoice issuer (required for PDF generation)
BILLING_ISSUER_NAME=
BILLING_ISSUER_VAT_ID=
BILLING_ISSUER_ADDRESS_LINE1=
BILLING_ISSUER_POSTAL_CODE=
BILLING_ISSUER_CITY=
BILLING_ISSUER_COUNTRY=DE
BILLING_ISSUER_EMAIL=
BILLING_ISSUER_BANK=
BILLING_ISSUER_IBAN=
BILLING_ISSUER_BIC=
BILLING_TAX_RATE_STANDARD=19
BILLING_TAX_RATE_REDUCED=7
BILLING_INVOICE_PDF_STORAGE_PATH=/data/invoices
BILLING_SKIP_FILE_CACHE=false
BILLING_DEFAULT_PAYMENT_PROCESSOR=stripe

# Stripe payment processing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:4500/invoices?payment=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:4500/invoices?payment=cancel

# Billing console base URLs for Stripe return redirects (tenant-aware)
# Default tenant uses BILLING_FRONTEND_URL; per-tenant overrides use TENANT_FRONTEND_URLS.
BILLING_FRONTEND_URL=http://localhost:4500
# Example: TENANT_FRONTEND_URLS=acme=https://billing.acme.com,corp=https://billing.corp.example
TENANT_FRONTEND_URLS=

# Provisioning provider configuration (optional, for availability checks)
HETZNER_API_TOKEN=
DIGITALOCEAN_API_TOKEN=

# Scheduler intervals (in milliseconds)
# Billing scheduler: processes recurring billing (default: 60000 = 1 minute)
BILLING_SCHEDULER_INTERVAL=60000
BILLING_SCHEDULER_BATCH_SIZE=100
# Expiration scheduler: processes subscription cancellations (default: 60000 = 1 minute)
EXPIRATION_SCHEDULER_INTERVAL=60000
EXPIRATION_SCHEDULER_BATCH_SIZE=100
# Reminder scheduler: sends renewal reminders (default: 3600000 = 1 hour)
REMINDER_SCHEDULER_INTERVAL=3600000
REMINDER_SCHEDULER_BATCH_SIZE=100
BACKORDER_RETRY_INTERVAL_MS=60000
BACKORDER_RETRY_BATCH_SIZE=100
INVOICE_OVERDUE_SCHEDULER_INTERVAL=86400000
INVOICE_OVERDUE_SCHEDULER_BATCH_SIZE=100
OPEN_POSITION_INVOICE_SCHEDULER_INTERVAL=86400000
REMINDER_DAYS=3
# Subscription update scheduler: SSH to provisioned hosts and run docker compose up -d --pull=always (default: 86400000 = 24 hours)
SUBSCRIPTION_UPDATE_SCHEDULER_INTERVAL=86400000

# DNS settings
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
DNS_BASE_DOMAIN=example.com

# Redis / BullMQ (queue provider in docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=agenstra-billing
REDIS_HOST_PORT=6380
QUEUE_ROLE=all
QUEUE_WORKER_CONCURRENCY=5
QUEUE_BULL_BOARD_ENABLED=true
QUEUE_BULL_BOARD_PATH=/admin/queues
QUEUE_BULL_BOARD_USERNAME=admin
QUEUE_BULL_BOARD_PASSWORD=bullmq

# Multi-tenancy (optional)
# Comma-separated tenant ids allowed for X-Tenant requests (includes "default" unless disabled below).
# Example: TENANTS=acme,corp — unset or empty allows only "default" when default is allowed.
TENANTS=agenstra,decabill,forepath
# Set to false to exclude the "default" tenant from the allowlist (clients must send X-Tenant).
TENANTS_ALLOW_DEFAULT=true

# When using STATIC_API_KEY on billing (optional single-tenant binding):
# STATIC_API_KEY_TENANT_ID=default
#
# Accepted risk AR-007: when STATIC_API_KEY is set and STATIC_API_KEY_TENANT_ID is unset,
# the key grants admin access to every tenant in TENANTS (selected via X-Tenant per request).
# See docs/agenstra/security/accepted-risks.md#ar-007--billing-multi-tenant-api-key-scope-static_api_key_tenant_id-unset
