# Copy to .env in this directory before running start-containers:
#   cp .start-containers.env.example .env

# Server
HOST=0.0.0.0
PORT=3400
NODE_ENV=development

# Database configuration
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=marpdown

# CORS configuration (comma-separated list of allowed origins)
# Example: CORS_ORIGIN=http://localhost:4600,http://localhost:4601
CORS_ORIGIN=http://localhost:4600

# Encryption key for presentation markdown and asset content (base64 encoded, 32 bytes)
ENCRYPTION_KEY=

# Authentication method: keycloak | users
# Presentation endpoints require an authenticated user (API key is not supported).
# - keycloak: Keycloak OAuth2 (requires Keycloak env vars)
# - users: Built-in user registration with JWT (requires JWT_SECRET)
AUTHENTICATION_METHOD=users

DISABLE_SIGNUP=false

# Environment variables for users authentication (when AUTHENTICATION_METHOD=users)
JWT_SECRET=

# Environment variables for Keycloak authentication (when AUTHENTICATION_METHOD=keycloak)
KEYCLOAK_SERVER_URL=
KEYCLOAK_AUTH_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_TOKEN_VALIDATION=online

# SMTP configuration (MailHog when using docker-compose)
# SMTP_HOST=mailhog and SMTP_PORT=1025 are used by default inside Docker.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@localhost

# MailHog host port mappings (when using docker-compose)
SMTP_HOST_PORT=1027
MAILHOG_PORT=8027

# Rate limiting (optional overrides)
RATE_LIMIT_ENABLED=
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Max upload size per presentation asset in bytes (default: 10485760 = 10 MiB)
MARPDOWN_MAX_ASSET_BYTES=10485760
