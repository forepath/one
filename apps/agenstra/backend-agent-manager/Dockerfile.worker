# -----------------------------------------------------------------------------
# Image:      agenstra-manager-worker
# Project:    backend-agent-manager — Nx target `worker-container-image`
# Registry:   ghcr.io/forepath/agenstra-manager-worker
# Base:       debian:trixie-slim
# User:       agenstra (APP_UID / APP_GID, default 10001); sudo: chown only (workspace bind mount)
# Exposes:    (none — idle worker; use `docker exec -u agenstra` for a shell)
# Build:      npx nx run backend-agent-manager:worker-container-image
# Run:        —
# Notes:      Includes Node.js, Nx, cursor-agent, and opencode for agent workloads
# -----------------------------------------------------------------------------
#
FROM docker.io/debian:trixie-slim

ARG APP_UID=10001
ARG APP_GID=10001

ENV NVM_DIR=/home/agenstra/.nvm
ENV NODE_VERSION=24.14.1
ENV HOME=/home/agenstra
ENV PATH="/home/agenstra/.local/bin:/home/agenstra/.opencode/bin:/home/agenstra/.nvm/versions/node/v${NODE_VERSION}/bin:${PATH}"

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    bash \
    ca-certificates \
    git \
    openssh-client \
    sudo && \
    groupadd --gid "${APP_GID}" agenstra && \
    useradd --uid "${APP_UID}" --gid "${APP_GID}" --create-home --home-dir /home/agenstra --shell /bin/bash agenstra && \
    echo 'agenstra ALL=(ALL) NOPASSWD: /usr/bin/chown' > /etc/sudoers.d/agenstra && \
    chmod 0440 /etc/sudoers.d/agenstra && \
    chown agenstra:agenstra /app && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | PROFILE=/dev/null bash && \
    . "${NVM_DIR}/nvm.sh" && \
    nvm install "${NODE_VERSION}" && \
    nvm alias default "${NODE_VERSION}" && \
    chown -R agenstra:agenstra /home/agenstra

RUN . "${NVM_DIR}/nvm.sh" && npm install -g nx && npm cache clean --force && \
    chown -R agenstra:agenstra /home/agenstra

RUN echo "deb http://deb.debian.org/debian bookworm main" > /etc/apt/sources.list.d/bookworm.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends -t bookworm curl --reinstall && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    rm -f /etc/apt/sources.list.d/bookworm.list

RUN install -d -o agenstra -g agenstra /home/agenstra/.local/bin /home/agenstra/.opencode/bin && \
    curl -fsSL https://cursor.com/install | bash -s -- --prefix /home/agenstra/.local && \
    chown -R agenstra:agenstra /home/agenstra/.local

RUN HOME=/home/agenstra bash -c 'curl -fsSL https://opencode.ai/install | bash' && \
    chown -R agenstra:agenstra /home/agenstra/.opencode

RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -euo pipefail' \
    'sudo chown -R agenstra:agenstra /app 2>/dev/null || true' \
    'exec tail -f /dev/null' \
    > /usr/local/bin/docker-entrypoint.sh && \
    chmod 755 /usr/local/bin/docker-entrypoint.sh && \
    chown agenstra:agenstra /usr/local/bin/docker-entrypoint.sh

USER ${APP_UID}:${APP_GID}

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
