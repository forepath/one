# -----------------------------------------------------------------------------
# Image:      agenstra-manager-ssh
# Project:    backend-agent-manager — Nx target `ssh-container-image`
# Registry:   ghcr.io/forepath/agenstra-manager-ssh
# Base:       debian:trixie-slim
# User:       agenstra (APP_UID / APP_GID, default 10001); sudo: chown, chpasswd, sshd
# Exposes:    22 (SSH)
# Build:      npx nx run backend-agent-manager:ssh-container-image
# Run:        —
# Notes:      Required runtime env: SSH_PASSWORD; sshd started via sudo from entrypoint
# -----------------------------------------------------------------------------
#
FROM docker.io/debian:trixie-slim

ARG APP_UID=10001
ARG APP_GID=10001

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    bash \
    ca-certificates \
    openssh-server \
    sudo \
    sshpass && \
    groupadd --gid "${APP_GID}" agenstra && \
    useradd --uid "${APP_UID}" --gid "${APP_GID}" --create-home --home-dir /home/agenstra --shell /bin/bash agenstra && \
    chown agenstra:agenstra /app /home/agenstra && \
    echo 'agenstra ALL=(ALL) NOPASSWD: /usr/bin/chown, /usr/sbin/chpasswd, /usr/sbin/sshd' > /etc/sudoers.d/agenstra && \
    chmod 0440 /etc/sudoers.d/agenstra && \
    mkdir -p /var/run/sshd && \
    sed -i -E 's/^#?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config && \
    sed -i -E 's/^#?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -euo pipefail' \
    'sudo chown -R agenstra:agenstra /app 2>/dev/null || true' \
    'sudo chown -R agenstra:agenstra /openclaw 2>/dev/null || true' \
    'if [ -z "${SSH_PASSWORD:-}" ]; then' \
    '  echo "SSH_PASSWORD is required" >&2' \
    '  exit 1' \
    'fi' \
    'echo "agenstra:${SSH_PASSWORD}" | sudo chpasswd' \
    'sudo /usr/sbin/sshd' \
    'exec tail -f /dev/null' \
    > /usr/local/bin/docker-entrypoint.sh && \
    chmod 755 /usr/local/bin/docker-entrypoint.sh && \
    chown agenstra:agenstra /usr/local/bin/docker-entrypoint.sh

EXPOSE 22

USER ${APP_UID}:${APP_GID}

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
