# -----------------------------------------------------------------------------
# Image:      agenstra-manager-api
# Project:    backend-agent-manager — Nx target `api-container-image`
# Registry:   ghcr.io/forepath/agenstra-manager-api
# Base:       debian:trixie-slim
# User:       agenstra (APP_UID / APP_GID, default 10001); member of `docker` group
# Exposes:    3000 (HTTP API), 8080 (WebSocket)
# Build:      npx nx run backend-agent-manager:api-container-image
# Run:        nx docker:run backend-agent-manager -p 3000:3000 -p 8080:8080
# Notes:      Mount Docker socket: -v /var/run/docker.sock:/var/run/docker.sock
#              Entrypoint (agenstra) uses sudo to sync socket GID, then sg docker for socket access
# -----------------------------------------------------------------------------
#
FROM docker.io/debian:trixie-slim

ARG APP_UID=10001
ARG APP_GID=10001
ARG DOCKER_GID=995

ENV HOST=0.0.0.0
ENV PORT=3000
ENV WEBSOCKET_PORT=8080
ENV NVM_DIR=/home/agenstra/.nvm
ENV NODE_VERSION=24.14.1
ENV HOME=/home/agenstra
ENV PATH="/home/agenstra/.nvm/versions/node/v${NODE_VERSION}/bin:${PATH}"

WORKDIR /app

EXPOSE ${PORT}
EXPOSE ${WEBSOCKET_PORT}

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    bash \
    ca-certificates \
    gnupg \
    lsb-release \
    util-linux \
    sudo && \
    groupadd --gid "${APP_GID}" agenstra && \
    useradd --uid "${APP_UID}" --gid "${APP_GID}" --create-home --home-dir /home/agenstra --shell /bin/bash agenstra && \
    echo 'agenstra ALL=(ALL) NOPASSWD: /usr/sbin/groupmod, /usr/sbin/groupadd, /usr/sbin/usermod' > /etc/sudoers.d/agenstra && \
    chmod 0440 /etc/sudoers.d/agenstra && \
    (groupadd --gid "${DOCKER_GID}" docker || groupmod -o -g "${DOCKER_GID}" docker) && \
    chown agenstra:agenstra /app && \
    mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null && \
    apt-get update && \
    apt-get install -y --no-install-recommends docker-ce-cli && \
    groupmod -o -g "${DOCKER_GID}" docker && \
    usermod -aG docker agenstra && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | PROFILE=/dev/null bash && \
    . "${NVM_DIR}/nvm.sh" && \
    nvm install "${NODE_VERSION}" && \
    nvm alias default "${NODE_VERSION}" && \
    chown -R agenstra:agenstra /home/agenstra

COPY --chown=agenstra:agenstra package*.json ./

RUN . "${NVM_DIR}/nvm.sh" && npm i && npm cache clean --force && \
    chown -R agenstra:agenstra /app

COPY --chown=agenstra:agenstra . /app

RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -euo pipefail' \
    'if [ -e /var/run/docker.sock ]; then' \
    '  docker_sock_gid="$(stat -c "%g" /var/run/docker.sock)"' \
    '  if getent group docker >/dev/null 2>&1; then' \
    '    sudo groupmod -o -g "${docker_sock_gid}" docker' \
    '  else' \
    '    sudo groupadd -g "${docker_sock_gid}" docker' \
    '  fi' \
    '  sudo usermod -aG docker agenstra' \
    '  exec sg docker -c '"'"'set -euo pipefail; . "${NVM_DIR}/nvm.sh"; exec node main.js'"'"'' \
    'fi' \
    '. "${NVM_DIR}/nvm.sh"' \
    'exec node main.js' \
    > /usr/local/bin/docker-entrypoint.sh && \
    chmod 755 /usr/local/bin/docker-entrypoint.sh && \
    chown agenstra:agenstra /usr/local/bin/docker-entrypoint.sh

USER ${APP_UID}:${APP_GID}

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD curl -f "http://localhost:${PORT}/api/health" || exit 1

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
