# -----------------------------------------------------------------------------
# Image:      agenstra-manager-vnc
# Project:    backend-agent-manager — Nx target `vnc-container-image`
# Registry:   ghcr.io/forepath/agenstra-manager-vnc
# Base:       debian:trixie (desktop stack)
# User:       agenstra (APP_UID / APP_GID, default 10001); sudo: chown only (context bind mount)
# Exposes:    6080 (noVNC / websockify; TigerVNC on display :1 internally)
# Build:      npx nx run backend-agent-manager:vnc-container-image
# Run:        nx docker:run backend-agent-manager -p 6080:6080
# Notes:      Required runtime env: VNC_PASSWORD
#              Optional: VNC_DISPLAY, VNC_RESOLUTION, VNC_DEPTH
#              Agent workspace mount path: /home/agenstra/environment
# -----------------------------------------------------------------------------
#
FROM docker.io/debian:trixie

ARG APP_UID=10001
ARG APP_GID=10001

WORKDIR /home/agenstra/environment

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    bash \
    ca-certificates \
    sudo \
    tigervnc-standalone-server \
    tigervnc-common \
    tigervnc-tools \
    xfce4 \
    xfce4-goodies \
    chromium \
    x11-utils \
    x11-xserver-utils \
    dbus-x11 \
    fluxbox \
    supervisor \
    net-tools \
    openssl \
    novnc \
    websockify \
    nano \
    htop \
    vim \
    git && \
    groupadd --gid "${APP_GID}" agenstra && \
    useradd --uid "${APP_UID}" --gid "${APP_GID}" --create-home --home-dir /home/agenstra --shell /bin/bash agenstra && \
    echo 'agenstra ALL=(ALL) NOPASSWD: /usr/bin/chown' > /etc/sudoers.d/agenstra && \
    chmod 0440 /etc/sudoers.d/agenstra && \
    mkdir -p /home/agenstra/environment && \
    chown -R agenstra:agenstra /home/agenstra && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/agenstra/.config/tigervnc && \
    printf '%s\n' \
    '#!/bin/bash' \
    'unset SESSION_MANAGER' \
    'unset DBUS_SESSION_BUS_ADDRESS' \
    'export XKL_XMODMAP_DISABLE=1' \
    '[ -r "$HOME/.Xresources" ] && xrdb "$HOME/.Xresources"' \
    'xsetroot -solid grey' \
    'vncconfig -iconic &' \
    'exec startxfce4' \
    > /home/agenstra/.config/tigervnc/xstartup && \
    chmod +x /home/agenstra/.config/tigervnc/xstartup && \
    chown -R agenstra:agenstra /home/agenstra/.config

RUN mkdir -p /home/agenstra/.config/xfce4/xfconf/xfce-perchannel-xml && \
    printf '%s\n' \
    '<?xml version="1.0" encoding="UTF-8"?>' \
    '<channel name="xfce4-settings" version="1.0">' \
    '  <property name="PreferredWebBrowser" type="string" value="chromium"/>' \
    '</channel>' \
    > /home/agenstra/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-settings.xml && \
    chown -R agenstra:agenstra /home/agenstra/.config/xfce4

RUN sed -i 's|Exec=/usr/bin/chromium %U|Exec=/usr/bin/chromium --no-sandbox --disable-dev-shm-usage --display=:1 %U|g' \
    /usr/share/applications/chromium.desktop

RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -e' \
    'find "$HOME" -type f -exec grep -l WebBrowser {} \; -delete 2>/dev/null || true' \
    > /usr/local/bin/cleanup-desktop.sh && \
    chmod +x /usr/local/bin/cleanup-desktop.sh && \
    chown agenstra:agenstra /usr/local/bin/cleanup-desktop.sh

RUN printf '%s\n' \
    '[Desktop Entry]' \
    'Type=Application' \
    'Name=Clean WebBrowser' \
    'Exec=/usr/local/bin/cleanup-desktop.sh' \
    'StartupNotify=true' \
    'NoDisplay=false' \
    'X-GNOME-Autostart-enabled=true' \
    'OnlyShowIn=XFCE;' \
    > /usr/share/applications/clean-webbrowser.desktop

RUN mkdir -p /home/agenstra/.config/autostart /home/agenstra/Desktop && \
    ln -sf /usr/share/applications/chromium.desktop /home/agenstra/.config/autostart/chromium.desktop && \
    ln -sf /usr/share/applications/clean-webbrowser.desktop /home/agenstra/.config/autostart/clean-webbrowser.desktop && \
    ln -sf /usr/share/applications/chromium.desktop /home/agenstra/Desktop/chromium.desktop && \
    chown -R agenstra:agenstra /home/agenstra/.config/autostart /home/agenstra/Desktop

RUN mkdir -p /home/agenstra/.novnc/ssl && \
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
    -keyout /home/agenstra/.novnc/ssl/novnc.key \
    -out /home/agenstra/.novnc/ssl/novnc.crt \
    -subj "/O=NoVNC/CN=localhost" && \
    chmod 600 /home/agenstra/.novnc/ssl/novnc.key && \
    chown -R agenstra:agenstra /home/agenstra/.novnc

RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -euo pipefail' \
    'sudo chown -R agenstra:agenstra /home/agenstra/environment 2>/dev/null || true' \
    'export VNC_DISPLAY="${VNC_DISPLAY:-:1}"' \
    'export VNC_SETUP_DISPLAY="${VNC_SETUP_DISPLAY:-:99}"' \
    'export VNC_RESOLUTION="${VNC_RESOLUTION:-1920x1080}"' \
    'export VNC_DEPTH="${VNC_DEPTH:-24}"' \
    'if [ -z "${VNC_PASSWORD:-}" ]; then' \
    '  echo "VNC_PASSWORD is required" >&2' \
    '  exit 1' \
    'fi' \
    'touch "$HOME/.Xauthority"' \
    'chmod 600 "$HOME/.Xauthority"' \
    'mkdir -p "$HOME/.config/tigervnc"' \
    'echo "$VNC_PASSWORD" | vncpasswd -f > "$HOME/.config/tigervnc/passwd"' \
    'chmod 600 "$HOME/.config/tigervnc/passwd"' \
    'vncserver -kill "${VNC_DISPLAY}" 2>/dev/null || true' \
    'rm -rf "/tmp/.X${VNC_DISPLAY#:}-lock" "/tmp/.X11-unix/X${VNC_DISPLAY#:}" 2>/dev/null || true' \
    'if [ ! -f "$HOME/.config/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml" ]; then' \
    '  vncserver "${VNC_SETUP_DISPLAY}" -geometry "${VNC_RESOLUTION}" -depth "${VNC_DEPTH}" -localhost no -SecurityTypes VncAuth' \
    '  for _ in $(seq 1 120); do' \
    '    if [ -f "$HOME/.config/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml" ]; then' \
    '      break' \
    '    fi' \
    '    sleep 0.5' \
    '  done' \
    '  vncserver -kill "${VNC_SETUP_DISPLAY}" || true' \
    'fi' \
    'vncserver "${VNC_DISPLAY}" -geometry "${VNC_RESOLUTION}" -depth "${VNC_DEPTH}" -localhost no -SecurityTypes VncAuth' \
    'websockify -D --web /usr/share/novnc/ --cert "$HOME/.novnc/ssl/novnc.crt" --key "$HOME/.novnc/ssl/novnc.key" 6080 localhost:5901' \
    'exec tail -f /dev/null' \
    > /usr/local/bin/docker-entrypoint.sh && \
    chmod 755 /usr/local/bin/docker-entrypoint.sh && \
    chown agenstra:agenstra /usr/local/bin/docker-entrypoint.sh

EXPOSE 6080

USER ${APP_UID}:${APP_GID}

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
