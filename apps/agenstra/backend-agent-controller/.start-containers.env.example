# Environment variables for the provisioning providers
HETZNER_API_TOKEN=
DIGITALOCEAN_API_TOKEN=

# Environment variables for encryption
ENCRYPTION_KEY=

# Client workspace endpoint SSRF guardrails (agent-manager base URLs stored per client)
# Production: set CLIENT_ENDPOINT_ALLOWED_HOSTS to comma-separated hostnames or * (see docs).
# CLIENT_ENDPOINT_ALLOWED_HOSTS=partner.example.com,am.other-customer.example
# CLIENT_ENDPOINT_ALLOW_INSECURE_HTTP=false
# CLIENT_ENDPOINT_ALLOW_INTERNAL_HOST=false
# CLIENT_ENDPOINT_TLS_REJECT_UNAUTHORIZED=true

# Environment variables for the authentication method
# AUTHENTICATION_METHOD: api-key | keycloak | users (default: api-key when STATIC_API_KEY set, else keycloak)
# - api-key: Static API key auth (requires STATIC_API_KEY)
# - keycloak: Keycloak OAuth2 (requires Keycloak env vars)
# - users: Built-in user registration with JWT (requires JWT_SECRET)
AUTHENTICATION_METHOD=api-key

# Environment variables for disabling signup
DISABLE_SIGNUP=false

# Environment variables for static API key authentication (when AUTHENTICATION_METHOD=api-key)
STATIC_API_KEY=

# Environment variables for users authentication (when AUTHENTICATION_METHOD=users)
JWT_SECRET=

# SMTP configuration (MailHog when using docker-compose)
# SMTP_HOST=mailhog and SMTP_PORT=1025 are used by default when running in Docker
# For production SMTP: set SMTP_USER and SMTP_PASSWORD; use port 465 for SMTPS
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@localhost
# Optional brand block in transactional emails (falls back to BILLING_ISSUER_* if set)
EMAIL_COMPANY_NAME=
EMAIL_COMPANY_ADDRESS_LINE1=
EMAIL_COMPANY_POSTAL_CODE=
EMAIL_COMPANY_CITY=
EMAIL_COMPANY_COUNTRY=
EMAIL_COMPANY_VAT_ID=
EMAIL_COMPANY_EMAIL=

# Redis / BullMQ (queue provider in docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=agenstra-controller
REDIS_HOST_PORT=6379
QUEUE_ROLE=all
QUEUE_WORKER_CONCURRENCY=5
QUEUE_BULL_BOARD_ENABLED=true
QUEUE_BULL_BOARD_PATH=/admin/queues
QUEUE_BULL_BOARD_USERNAME=admin
QUEUE_BULL_BOARD_PASSWORD=bullmq
