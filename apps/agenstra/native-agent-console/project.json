{
  "name": "agenstra-native-agent-console",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/agenstra/native-agent-console/src",
  "tags": [],
  "implicitDependencies": ["agenstra-frontend-agent-console"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": false
      },
      "outputs": [
        "{workspaceRoot}/dist/apps/agenstra/native-agent-console",
        "{workspaceRoot}/dist/apps/frontend-agent-console"
      ],
      "configurations": {
        "development": {
          "commands": [
            "nx build frontend-agent-console --configuration=development",
            "nx run frontend-agent-console:prebuild-server --configuration=development",
            "nx run frontend-agent-console:server",
            "tsc -p apps/agenstra/native-agent-console/tsconfig.json",
            "node -e \"require('fs').writeFileSync('dist/apps/agenstra/native-agent-console/package.json', JSON.stringify({type:'commonjs'}, null, 2))\"",
            "cp -r dist/apps/frontend-agent-console/server dist/apps/agenstra/native-agent-console/server",
            "cp apps/agenstra/native-agent-console/package-server.json dist/apps/agenstra/native-agent-console/server/package.json",
            "npm i --omit=dev --prefix dist/apps/agenstra/native-agent-console/server",
            "cp apps/agenstra/native-agent-console/public/assets/images/icon.ico dist/apps/agenstra/native-agent-console/icon.ico",
            "cp apps/agenstra/native-agent-console/public/assets/images/icon.png dist/apps/agenstra/native-agent-console/icon.png",
            "cp apps/agenstra/native-agent-console/package.json dist/apps/agenstra/native-agent-console/package.json",
            "cp apps/agenstra/native-agent-console/forge.config.js dist/apps/agenstra/native-agent-console/forge.config.js",
            "npm i --omit=dev --prefix dist/apps/agenstra/native-agent-console"
          ]
        },
        "production": {
          "commands": [
            "nx build frontend-agent-console --configuration=production",
            "nx run frontend-agent-console:prebuild-server --configuration=production",
            "nx run frontend-agent-console:server",
            "tsc -p apps/agenstra/native-agent-console/tsconfig.json",
            "node -e \"require('fs').writeFileSync('dist/apps/agenstra/native-agent-console/package.json', JSON.stringify({type:'commonjs'}, null, 2))\"",
            "cp -r dist/apps/frontend-agent-console/server dist/apps/agenstra/native-agent-console/server",
            "cp apps/agenstra/native-agent-console/package-server.json dist/apps/agenstra/native-agent-console/server/package.json",
            "npm i --omit=dev --prefix dist/apps/agenstra/native-agent-console/server",
            "cp apps/agenstra/native-agent-console/public/assets/images/icon.ico dist/apps/agenstra/native-agent-console/icon.ico",
            "cp apps/agenstra/native-agent-console/public/assets/images/icon.png dist/apps/agenstra/native-agent-console/icon.png",
            "cp apps/agenstra/native-agent-console/package.json dist/apps/agenstra/native-agent-console/package.json",
            "cp apps/agenstra/native-agent-console/forge.config.js dist/apps/agenstra/native-agent-console/forge.config.js",
            "npm i --omit=dev --prefix dist/apps/agenstra/native-agent-console"
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": false
      },
      "configurations": {
        "development": {
          "commands": [
            "nx build native-agent-console --configuration=development",
            "electron dist/apps/agenstra/native-agent-console/main.js"
          ]
        },
        "production": {
          "commands": [
            "nx build native-agent-console --configuration=production",
            "electron dist/apps/agenstra/native-agent-console/main.js"
          ]
        }
      },
      "defaultConfiguration": "development"
    },
    "package": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": false
      },
      "configurations": {
        "development-linux": {
          "commands": [
            "nx build native-agent-console --configuration=development",
            "cd dist/apps/agenstra/native-agent-console && npx electron-forge make --platform linux"
          ]
        },
        "development-windows": {
          "commands": [
            "nx build native-agent-console --configuration=development",
            "cd dist/apps/agenstra/native-agent-console && npx electron-forge make --platform win32"
          ]
        },
        "production-linux": {
          "commands": [
            "nx build native-agent-console --configuration=production",
            "sed -i \"s/0.0.0/${RELEASE_VERSION}/g\" dist/apps/agenstra/native-agent-console/package.json",
            "sed -i \"s/0.0.0/${RELEASE_VERSION}/g\" dist/apps/agenstra/native-agent-console/server/package.json",
            "cd dist/apps/agenstra/native-agent-console && npx electron-forge make --platform linux"
          ]
        },
        "production-windows": {
          "commands": [
            "nx build native-agent-console --configuration=production",
            "sed -i \"s/0.0.0/${RELEASE_VERSION}/g\" dist/apps/agenstra/native-agent-console/package.json",
            "sed -i \"s/0.0.0/${RELEASE_VERSION}/g\" dist/apps/agenstra/native-agent-console/server/package.json",
            "cd dist/apps/agenstra/native-agent-console && npx electron-forge make --platform win32"
          ]
        }
      },
      "defaultConfiguration": "development"
    },
    "sbom": {
      "executor": "@forepath/sbom:sbom",
      "dependsOn": ["sbom:build", "build"]
    }
  }
}
