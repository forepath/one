# -----------------------------------------------------------------------------
# Image:      agenstra-billing-console-server
# Project:    frontend-billing-console — Nx target `server-container-image`
# Registry:   ghcr.io/forepath/agenstra-billing-console-server
# Base:       node:24.14.1-alpine
# User:       node (APP_UID / APP_GID, default 1000)
# Exposes:    4500 (Express static server)
# Build:      npx nx run frontend-billing-console:server-container-image
# Run:        nx docker:run frontend-billing-console -p 4500:4500
# Notes:      Optional runtime env CONFIG=<url> for GET /config JSON merge
# -----------------------------------------------------------------------------
#
FROM docker.io/node:24.14.1-alpine

ARG APP_UID=1000
ARG APP_GID=1000

ENV HOST=0.0.0.0
ENV PORT=4500

WORKDIR /app

EXPOSE ${PORT}

COPY --chown=${APP_UID}:${APP_GID} package*.json ./

RUN npm i --omit=dev && npm cache clean --force && chown -R "${APP_UID}:${APP_GID}" /app

COPY --chown=${APP_UID}:${APP_GID} . /app

USER ${APP_UID}:${APP_GID}

CMD [ "node", "server.cjs" ]
