# -----------------------------------------------------------------------------
# Image:      forepath-landingpage-server
# Project:    forepath-frontend-landingpage — Nx target `server-container-image`
# Registry:   ghcr.io/forepath/forepath-landingpage-server
# Base:       node:24.14.1-alpine
# User:       node (APP_UID / APP_GID, default 1000)
# Exposes:    4000 (Express static server)
# Build:      npx nx run forepath-frontend-landingpage:server-container-image
# -----------------------------------------------------------------------------
#
FROM docker.io/node:24.14.1-alpine

ARG APP_UID=1000
ARG APP_GID=1000

ENV HOST=0.0.0.0
ENV PORT=4000

WORKDIR /app

EXPOSE ${PORT}

# CVE-2026-59873: upgrade npm so nested tar is >= 7.5.19
RUN npm install -g npm@11.18.0 && npm cache clean --force

COPY --chown=${APP_UID}:${APP_GID} . /app

USER ${APP_UID}:${APP_GID}

CMD [ "node", "server.mjs" ]
