{
  "name": "frontend-forepath",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/frontend-forepath/src",
  "tags": ["type:app", "scope:frontend"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/frontend-forepath",
        "index": "apps/frontend-forepath/src/index.html",
        "browser": "apps/frontend-forepath/src/main.ts",
        "polyfills": ["zone.js", "apps/frontend-forepath/src/polyfills.ts"],
        "tsConfig": "apps/frontend-forepath/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/frontend-forepath/public"
          }
        ],
        "styles": [
          "node_modules/cookieconsent/build/cookieconsent.min.css",
          "apps/frontend-forepath/src/styles.scss"
        ],
        "server": "apps/frontend-forepath/src/main.server.ts",
        "ssr": {
          "entry": "apps/frontend-forepath/src/server.ts"
        },
        "prerender": true,
        "scripts": [
          "node_modules/cookieconsent/build/cookieconsent.min.js",
          "node_modules/@popperjs/core/dist/umd/popper.min.js",
          "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"
        ],
        "localize": true,
        "i18nMissingTranslation": "warning"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "libs/domains/framework/frontend/util-configuration/src/lib/environment.ts",
              "with": "libs/domains/framework/frontend/util-configuration/src/lib/environment.forepath.production.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "libs/domains/framework/frontend/util-configuration/src/lib/environment.ts",
              "with": "libs/domains/framework/frontend/util-configuration/src/lib/environment.forepath.ts"
            }
          ]
        },
        "en": {
          "localize": ["en"]
        },
        "de": {
          "localize": ["de"]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "hmr": false,
        "port": 4400
      },
      "configurations": {
        "production": {
          "buildTarget": "frontend-forepath:build:production,en"
        },
        "development": {
          "buildTarget": "frontend-forepath:build:development,en"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n-angular": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "frontend-forepath:build",
        "outputPath": "apps/frontend-forepath/src/i18n"
      }
    },
    "extract-i18n": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../remove-context-groups.cjs src/i18n/messages.xlf",
        "cwd": "apps/frontend-forepath"
      },
      "dependsOn": ["extract-i18n-angular"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/frontend-forepath/jest.config.cts",
        "tsConfig": "apps/frontend-forepath/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "frontend-forepath:build",
        "port": 4400,
        "staticFilePath": "dist/apps/frontend-forepath/browser",
        "spa": true
      }
    },
    "build-delegating-server": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/apps/frontend-forepath-delegating-server"
      ],
      "options": {
        "command": "mkdir -p dist/apps/frontend-forepath-delegating-server/server && npx tsc apps/frontend-forepath/src/delegating-server.ts --outDir dist/apps/frontend-forepath-delegating-server/server --target es2022 --module esnext --moduleResolution node --allowSyntheticDefaultImports --esModuleInterop --skipLibCheck --declaration false --sourceMap false --removeComments true",
        "cwd": "."
      }
    },
    "postbuild": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cp dist/apps/frontend-forepath-delegating-server/server/delegating-server.js dist/apps/frontend-forepath/server/server.mjs && cp -r dist/apps/frontend-forepath/browser dist/apps/frontend-forepath/server/browser"
      },
      "dependsOn": ["build", "build-delegating-server"]
    },
    "server-container-image": {
      "dependsOn": ["postbuild"],
      "cache": false,
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "engine": "docker",
        "file": "apps/frontend-forepath/Dockerfile.server",
        "context": "dist/apps/frontend-forepath/server"
      },
      "configurations": {
        "test": {
          "load": true,
          "tags": ["ghcr.io/forepath/forepath-site-server:latest"]
        },
        "release": {
          "push": true,
          "tags": [
            "ghcr.io/forepath/forepath-site-server:latest",
            "ghcr.io/forepath/forepath-site-server:$VERSION"
          ]
        }
      },
      "defaultConfiguration": "test"
    }
  },
  "i18n": {
    "sourceLocale": "en",
    "locales": {
      "de": "apps/frontend-forepath/src/i18n/messages.de.xlf"
    }
  }
}
