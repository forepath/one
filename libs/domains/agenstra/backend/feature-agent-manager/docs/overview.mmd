flowchart TB
    subgraph HTTP["🔷 HTTP REST API (/api/agents)"]
        direction TB
        HTTP_USE["Use Case: CRUD Operations<br/>One-time Requests<br/>Request-Response Pattern"]
        HTTP_USE --> HTTP1["📝 Create Agent<br/>POST /api/agents<br/>Returns: Agent + Password"]
        HTTP_USE --> HTTP2["📋 List Agents<br/>GET /api/agents?limit&offset<br/>Returns: Paginated List"]
        HTTP_USE --> HTTP3["🔍 Get Agent<br/>GET /api/agents/:id<br/>Returns: Agent Details"]
        HTTP_USE --> HTTP4["✏️ Update Agent<br/>POST /api/agents/:id<br/>Returns: Updated Agent"]
        HTTP_USE --> HTTP5["🗑️ Delete Agent<br/>DELETE /api/agents/:id<br/>Returns: 204 No Content"]
        HTTP_USE --> HTTP6["🤖 List Models<br/>GET /api/agents/:id/models<br/>Returns: Model id → name map"]
    end

    subgraph FILES["📁 HTTP REST API - File System (/api/agents/:id/files)"]
        direction TB
        FILES_USE["Use Case: File System Operations<br/>Read, Write, List, Create, Delete, Move<br/>Optional query context=app|config (default app)"]
        FILES_USE --> FILES1["📖 Read File<br/>GET /api/agents/:id/files/*path?context=<br/>Returns: File Content"]
        FILES_USE --> FILES2["✍️ Write File<br/>PUT /api/agents/:id/files/*path?context=<br/>Returns: 204 No Content"]
        FILES_USE --> FILES3["📂 List Directory<br/>GET /api/agents/:id/files?path=&context=<br/>Returns: File Nodes"]
        FILES_USE --> FILES4["➕ Create File/Dir<br/>POST /api/agents/:id/files/*path<br/>Returns: 201 Created"]
        FILES_USE --> FILES5["🗑️ Delete File/Dir<br/>DELETE /api/agents/:id/files/*path<br/>Returns: 204 No Content"]
        FILES_USE --> FILES6["📦 Move File/Dir<br/>PATCH /api/agents/:id/files/*path<br/>Returns: 204 No Content"]
    end

    subgraph ENV["🔐 HTTP REST API - Environment Variables (/api/agents/:id/environment)"]
        direction TB
        ENV_USE["Use Case: Environment Variable Management<br/>CRUD Operations<br/>Container Environment Variables"]
        ENV_USE --> ENV1["📋 List Variables<br/>GET /api/agents/:id/environment?limit&offset<br/>Returns: Paginated List"]
        ENV_USE --> ENV2["🔢 Count Variables<br/>GET /api/agents/:id/environment/count<br/>Returns: Count"]
        ENV_USE --> ENV3["➕ Create Variable<br/>POST /api/agents/:id/environment<br/>Returns: Created Variable"]
        ENV_USE --> ENV4["✏️ Update Variable<br/>PUT /api/agents/:id/environment/:id<br/>Returns: Updated Variable"]
        ENV_USE --> ENV5["🗑️ Delete Variable<br/>DELETE /api/agents/:id/environment/:id<br/>Returns: 204 No Content"]
        ENV_USE --> ENV6["🗑️ Delete All Variables<br/>DELETE /api/agents/:id/environment<br/>Returns: Deleted Count"]
    end

    subgraph AUTO_HTTP["🧪 HTTP - Automation helpers (/api/agents/:id)"]
        direction TB
        AUTO_HTTP_USE["Use Case: Clean tree &amp; verifier runs<br/>Ticket automation support"]
        AUTO_HTTP_USE --> AUTO1["🧹 Prepare clean workspace<br/>POST .../vcs/workspace/prepare-clean<br/>Returns: 204"]
        AUTO_HTTP_USE --> AUTO2["✅ Run verifier commands<br/>POST .../automation/verify-commands<br/>Returns: exit codes + output"]
    end

    subgraph WS["🔶 WebSocket Gateway (namespace: /agents)"]
        direction TB
        WS_USE["Use Case: Real-time Communication<br/>Bidirectional Messages<br/>Persistent Connection"]
        WS_USE --> WS1["🔐 Authentication & Connection<br/>1. Connect to WebSocket<br/>2. Login with credentials<br/>3. Session established<br/>4. Chat history restored"]
        WS_USE --> WS2["💬 Chat Messages<br/>1. Apply incoming filters (drop/flag)<br/>2. Send filter result message<br/>3. Check if first message (no chat history)<br/>4. Send initialization message if needed<br/>5. Send chat message<br/>6. Persist message to database (with filtered flag)<br/>7. Broadcast to all clients<br/>8. Forward to container stdin<br/>9. Capture agent response<br/>10. Apply outgoing filters (drop/flag)<br/>11. Send filter result message<br/>12. Persist agent response (with filtered flag)<br/>13. Broadcast agent response"]
    end

    Start([Agent Manager Feature]) --> HTTP
    Start --> FILES
    Start --> ENV
    Start --> AUTO_HTTP
    Start --> WS

    HTTP -.->|"Stateless<br/>Request-Response"| HTTP_USE
    FILES -.->|"Stateless<br/>Request-Response"| FILES_USE
    ENV -.->|"Stateless<br/>Request-Response"| ENV_USE
    AUTO_HTTP -.->|"Stateless<br/>Request-Response"| AUTO_HTTP_USE
    WS -.->|"Stateful<br/>Persistent Connection"| WS_USE

