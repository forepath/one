flowchart TB
    subgraph HTTP["🔷 HTTP REST API (/api/clients)"]
        direction TB
        HTTP_USE["Use Case: Client Management<br/>One-time Requests<br/>Request-Response Pattern"]
        HTTP_USE --> HTTP1["📝 Create Client<br/>POST /api/clients<br/>Returns: Client + API Key (if API_KEY)"]
        HTTP_USE --> HTTP2["📋 List Clients<br/>GET /api/clients?limit&offset<br/>Returns: Paginated List"]
        HTTP_USE --> HTTP3["🔍 Get Client<br/>GET /api/clients/:id<br/>Returns: Client Details"]
        HTTP_USE --> HTTP4["✏️ Update Client<br/>POST /api/clients/:id<br/>Returns: Updated Client"]
        HTTP_USE --> HTTP5["🗑️ Delete Client<br/>DELETE /api/clients/:id<br/>Returns: 204 No Content"]
    end

    subgraph USERS["👥 HTTP REST API - Client User Management (/api/clients/:id/users)"]
        direction TB
        USERS_USE["Use Case: Per-Client Permissions<br/>keycloak/users auth only<br/>Add/Remove users by email"]
        USERS_USE --> USERS1["📋 List Client Users<br/>GET /api/clients/:id/users<br/>Returns: ClientUserResponseDto[]"]
        USERS_USE --> USERS2["➕ Add User to Client<br/>POST /api/clients/:id/users<br/>Accepts: AddClientUserDto"]
        USERS_USE --> USERS3["🗑️ Remove User from Client<br/>DELETE /api/clients/:id/users/:relationshipId<br/>Returns: 204 No Content"]
    end

    subgraph PROXY["🔷 HTTP REST API - Proxied Agent Operations (/api/clients/:id/agents)"]
        direction TB
        PROXY_USE["Use Case: Agent Management via Client<br/>Proxy to Remote Agent-Manager<br/>Request-Response Pattern"]
        PROXY_USE --> PROXY1["📝 Create Agent (Proxied)<br/>POST /api/clients/:id/agents<br/>Returns: Agent + Password<br/>Saves credentials for WS"]
        PROXY_USE --> PROXY2["📋 List Agents (Proxied)<br/>GET /api/clients/:id/agents?limit&offset<br/>Returns: Paginated Agent List"]
        PROXY_USE --> PROXY3["🔍 Get Agent (Proxied)<br/>GET /api/clients/:id/agents/:agentId<br/>Returns: Agent Details"]
        PROXY_USE --> PROXY3B["🤖 List Models (Proxied)<br/>GET /api/clients/:id/agents/:agentId/models<br/>Returns: Model id → name map"]
        PROXY_USE --> PROXY4["✏️ Update Agent (Proxied)<br/>POST /api/clients/:id/agents/:agentId<br/>Returns: Updated Agent"]
        PROXY_USE --> PROXY5["🗑️ Delete Agent (Proxied)<br/>DELETE /api/clients/:id/agents/:agentId<br/>Returns: 204 No Content"]
    end

    subgraph FILES["📁 HTTP REST API - Proxied File System (/api/clients/:id/agents/:agentId/files)"]
        direction TB
        FILES_USE["Use Case: File System Operations via Client<br/>Proxy to Remote Agent-Manager<br/>Optional query context=app|config (config needs workspace management)"]
        FILES_USE --> FILES1["📖 Read File (Proxied)<br/>GET /api/clients/:id/agents/:agentId/files/*path?context=<br/>Returns: File Content (base64)"]
        FILES_USE --> FILES2["✍️ Write File (Proxied)<br/>PUT /api/clients/:id/agents/:agentId/files/*path?context=<br/>Returns: 204 No Content"]
        FILES_USE --> FILES3["📂 List Directory (Proxied)<br/>GET /api/clients/:id/agents/:agentId/files?path=&context=<br/>Returns: File Nodes"]
        FILES_USE --> FILES4["➕ Create File/Dir (Proxied)<br/>POST /api/clients/:id/agents/:agentId/files/*path<br/>Returns: 201 Created"]
        FILES_USE --> FILES5["🗑️ Delete File/Dir (Proxied)<br/>DELETE /api/clients/:id/agents/:agentId/files/*path<br/>Returns: 204 No Content"]
    end

    subgraph ENV["🌍 HTTP REST API - Proxied Environment Variables (/api/clients/:id/agents/:agentId/environment)"]
        direction TB
        ENV_USE["Use Case: Environment Variable Management via Client<br/>Proxy to Remote Agent-Manager<br/>Request-Response Pattern"]
        ENV_USE --> ENV1["📋 List Environment Variables (Proxied)<br/>GET /api/clients/:id/agents/:agentId/environment?limit&offset<br/>Returns: Paginated Environment Variables"]
        ENV_USE --> ENV2["🔢 Count Environment Variables (Proxied)<br/>GET /api/clients/:id/agents/:agentId/environment/count<br/>Returns: Count"]
        ENV_USE --> ENV3["➕ Create Environment Variable (Proxied)<br/>POST /api/clients/:id/agents/:agentId/environment<br/>Returns: Created Environment Variable"]
        ENV_USE --> ENV4["✏️ Update Environment Variable (Proxied)<br/>PUT /api/clients/:id/agents/:agentId/environment/:envVarId<br/>Returns: Updated Environment Variable"]
        ENV_USE --> ENV5["🗑️ Delete Environment Variable (Proxied)<br/>DELETE /api/clients/:id/agents/:agentId/environment/:envVarId<br/>Returns: 204 No Content"]
        ENV_USE --> ENV6["🗑️ Delete All Environment Variables (Proxied)<br/>DELETE /api/clients/:id/agents/:agentId/environment<br/>Returns: Deleted Count"]
    end

    subgraph WS["🔶 WebSocket Gateway (namespace: /clients)"]
        direction TB
        WS_USE["Use Case: Real-time Event Forwarding<br/>Bidirectional Messages<br/>Persistent Connection"]
        WS_USE --> WS1["🔐 Client Context Setup<br/>1. Connect to WebSocket (auth: api-key/Keycloak/users)<br/>2. setClient with clientId (per-client access check)<br/>3. Remote connection established<br/>4. Auto-authentication (API_KEY/Keycloak)"]
        WS_USE --> WS2["📤 Event Forwarding<br/>1. forward event with agentId?<br/>2. Auto-login if agentId provided<br/>3. Forward to remote agent-manager WS<br/>4. Relay responses back to client"]
    end

    Start([Agent Controller Feature]) --> HTTP
    Start --> USERS
    Start --> PROXY
    Start --> FILES
    Start --> ENV
    Start --> WS

    HTTP -.->|"Stateless<br/>Request-Response"| HTTP_USE
    USERS -.->|"Per-Client<br/>Permissions"| USERS_USE
    PROXY -.->|"Proxy to Remote<br/>Agent-Manager"| PROXY_USE
    FILES -.->|"Proxy to Remote<br/>Agent-Manager"| FILES_USE
    ENV -.->|"Proxy to Remote<br/>Agent-Manager"| ENV_USE
    WS -.->|"Stateful<br/>Persistent Connection"| WS_USE

