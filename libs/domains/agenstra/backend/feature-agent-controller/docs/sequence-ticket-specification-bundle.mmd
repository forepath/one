sequenceDiagram
    participant Client as Agent_console
    participant API as TicketsController
    participant Svc as TicketsService
    participant DB as Database
    participant WS as Tickets_board_socket

    Client->>API: POST /tickets<br/>creationTemplate: specification
    API->>Svc: create(dto)
    Svc->>DB: BEGIN transaction
    Svc->>DB: INSERT parent ticket + CREATED activity
    loop Four SDD subtasks
        Svc->>DB: INSERT child ticket + CREATED activity
    end
    Svc->>DB: COMMIT
    loop Each saved ticket
        Svc->>WS: ticketUpsert + ticketActivityCreated
    end
    Svc-->>API: CreateTicketResponseDto + createdChildTickets
    API-->>Client: 201 Created
