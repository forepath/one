sequenceDiagram
    participant User
    participant BillingAPI
    participant CustomerProfilesService
    participant AvailabilityService
    participant ProvisioningService
    participant HetznerAPI
    participant Database

    %% requestedConfig includes service (controller|manager), authenticationMethod, smtp, keycloak, optional provisioning (controller only)
    User->>BillingAPI: POST /subscriptions (planId, requestedConfig with service)
    BillingAPI->>CustomerProfilesService: getByUserId(userId)
    CustomerProfilesService-->>BillingAPI: profile

    alt Profile missing or incomplete
        BillingAPI-->>User: 400 Customer billing profile must be complete
    else Profile complete
        note over BillingAPI: Merge plan.providerConfigDefaults + requestedConfig; strip region/location from requestedConfig if plan.allowCustomerLocationSelection is false; mirror region/location for Hetzner/DO; validateConfigSchema (incl. enum)
        BillingAPI->>AvailabilityService: checkAvailability(provider, region, serverType)
        AvailabilityService->>HetznerAPI: GET /server_types + /limits
        HetznerAPI-->>AvailabilityService: availability + limits
        AvailabilityService-->>BillingAPI: AvailabilityResponse

        alt Available
            BillingAPI->>Database: INSERT subscription
            BillingAPI->>Database: INSERT subscription_item
            note over BillingAPI: Generate SSH keypair; store encrypted private key on subscription_item; set effectiveConfig.sshPublicKey
            note over BillingAPI: Build userData: if service=manager use agent-manager.utils else agent-controller.utils
            BillingAPI->>ProvisioningService: provision(provider, config with userData)
            ProvisioningService->>HetznerAPI: POST /servers
            HetznerAPI-->>ProvisioningService: serverId
            ProvisioningService->>HetznerAPI: POST /firewalls/:id/attach
            ProvisioningService-->>BillingAPI: serverId
            BillingAPI->>Database: UPDATE subscription_item.provider_reference
            BillingAPI-->>User: 201 SubscriptionResponse
        else Not available
            BillingAPI->>Database: INSERT backorder (optional)
            BillingAPI-->>User: 400 Configuration not available
        end
    end
