#!/bin/bash

# Pre-commit hook for TSEF Nx monorepo
# This hook runs before each commit to ensure code quality and consistency

echo "🔍 Running pre-commit checks..."

# 1. Check code formatting with Prettier
echo "📝 Checking code formatting with Prettier..."
nx format:check
if [ $? -ne 0 ]; then
  echo "❌ Code formatting check failed. Please run 'nx format:write' to fix formatting issues."
  exit 1
fi

# 2. Security scan with Trivy (filesystem + config; CRITICAL gate per trivy.yaml)
echo "🔒 Running Trivy security scans..."
chmod +x tools/ci/trivy-pre-commit.sh
tools/ci/trivy-pre-commit.sh
if [ $? -ne 0 ]; then
  echo "❌ Trivy scan failed. Fix CRITICAL findings or document them in .trivyignore."
  echo "   See docs/agenstra/security/ci-security-scanning.md"
  exit 1
fi

# 3. Run linting on affected projects
echo "🔧 Running ESLint on affected projects..."
nx affected -t lint
if [ $? -ne 0 ]; then
  echo "❌ Linting failed. Please fix linting errors."
  exit 1
fi

# 4. Run tests on affected projects
echo "🧪 Running tests on affected projects..."
nx affected -t test
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Please fix failing tests."
  exit 1
fi

# 5. Build affected projects to ensure they compile
echo "🏗️  Building affected projects..."
nx affected -t build
if [ $? -ne 0 ]; then
  echo "❌ Build failed. Please fix build errors."
  exit 1
fi

# 6. Regenerate knowledge graph and stage artifacts for this commit
echo "📊 Regenerating knowledge graph..."
nx run graph:generate-kg
if [ $? -ne 0 ]; then
  echo "❌ Knowledge graph generation failed."
  exit 1
fi
git add graph/graph.json graph/graph.html

echo "✅ All pre-commit checks passed!"
